generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id                       Int      @id @default(autoincrement())
  name                     String   @unique
  slug                     String?  @unique
  koreanName               String?
  city                     String
  country                  String   @default("South Korea")
  universityType           String   @default("private")
  qsRanking                Int?
  qsRankingLabel           String?
  qsRankingYear            Int?
  rankingSourceNote        String?  @db.Text
  qsSourceUrl              String?
  sourceUrls               String[] @default([])
  lastVerifiedAt           DateTime?
  officialWebsite          String   @unique
  imageUrl                 String?
  logoUrl                  String?
  campusImageUrl           String?
  imageAlt                 String?
  imageSourceUrl           String?
  imageLastVerifiedAt      DateTime?
  description              String   @db.Text
  fullDescription          String?  @db.Text
  programs                 String[] @default([])
  tuitionMin               Int?
  tuitionMax               Int?
  tuitionCurrency          String   @default("KRW")
  admissionRequirements    String[] @default([])
  languagesOfInstruction   String[] @default([])
  scholarshipInfo          String?  @db.Text
  hasScholarships          Boolean? @default(false)
  hasDormitory             Boolean? @default(false)
  housingInfo              String?  @db.Text
  internationalStudentInfo String?  @db.Text
  studentLife              String?  @db.Text
  requiredDocuments        String[] @default([])
  applicationSteps         String[] @default([])
  studyLevels              String[] @default([])
  applicationDeadlines     Json?
  applicationOpenDate      DateTime?
  applicationDeadline      DateTime?
  scholarshipDeadline      DateTime?
  documentDeadline         DateTime?
  tags                     String[] @default([])
  contactEmail             String?
  contactPhone             String?
  contactAddress           String?
  mainColor                String   @default("#15397F")
  acceptanceRate           String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  savedBy                  SavedUniversity[]
  comparisonItems          ComparisonUniversity[]
  deadlineReminders        UserDeadline[]
  studentCouncil           StudentCouncil?
  studentCouncilRoles      StudentCouncilRole[]
  communityPosts           CommunityPost[]
  applications             UserApplication[]
  calendarEvents           CalendarEvent[]

  @@index([city])
  @@index([country])
  @@index([universityType])
  @@index([qsRanking])
  @@index([applicationDeadline])
}

model StudentCouncil {
  id                 Int                  @id @default(autoincrement())
  universityId       Int                  @unique
  name               String
  officialName       String?
  description        String               @db.Text
  websiteUrl         String?
  socialUrl          String?
  contactEmail       String?
  sourceUrl          String?
  verificationStatus String               @default("needs verification")
  lastVerifiedAt     DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  university         University           @relation(fields: [universityId], references: [id], onDelete: Cascade)
  roles              StudentCouncilRole[]

  @@index([verificationStatus])
}

model StudentCouncilRole {
  id                 Int            @id @default(autoincrement())
  councilId          Int
  universityId       Int
  adminUserId        Int?
  displayName        String?
  roleTitle          String
  department         String?
  description        String?        @db.Text
  responsibilities   String[]       @default([])
  contactEmail       String?
  contactUrl         String?
  avatarUrl          String?
  status             String         @default("pending")
  verificationStatus String         @default("needs verification")
  sourceUrl          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  council            StudentCouncil @relation(fields: [councilId], references: [id], onDelete: Cascade)
  university         University     @relation(fields: [universityId], references: [id], onDelete: Cascade)
  adminUser          AdminUser?     @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([councilId])
  @@index([universityId])
  @@index([adminUserId])
  @@index([status])
  @@index([verificationStatus])
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  councilRoles     StudentCouncilRole[]
  moderatorProfile ModeratorProfile?
  activityLogs     ModeratorActivityLog[]
  internalNotes    ModeratorInternalNote[]
}

model ModeratorProfile {
  id          Int       @id @default(autoincrement())
  adminUserId Int      @unique
  displayName String
  description String?  @db.Text
  defaultRole String?
  avatarUrl   String?
  contactEmail String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
}

model StudentUser {
  id                        Int                        @id @default(autoincrement())
  name                      String
  email                     String                     @unique
  passwordHash              String
  preferredMajor            String?
  preferredCity             String?
  preferredLevel            String?
  budgetMin                 Int?
  budgetMax                 Int?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  savedUniversities         SavedUniversity[]
  comparisonSets            ComparisonSet[]
  deadlineReminders         UserDeadline[]
  checklistItems            ChecklistItem[]
  recommendationPreferences RecommendationPreference[]
  communityPosts            CommunityPost[]
  communityComments         CommunityComment[]
  communityLikes            CommunityLike[]
  savedCommunityPosts       CommunitySavedPost[]
  communityReports          CommunityReport[]
  notifications             Notification[]
  analyticsEvents           AnalyticsEvent[]
  onboardingPreference      UserOnboardingPreference?
  applications              UserApplication[]
  documents                 UserDocument[]
  calendarEvents            CalendarEvent[]
}

model SavedUniversity {
  userId       Int
  universityId Int
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())

  user         StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  university   University  @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@id([userId, universityId])
  @@index([universityId])
}

model ComparisonSet {
  id        Int                    @id @default(autoincrement())
  userId    Int?
  name      String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  user      StudentUser?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     ComparisonUniversity[]
}

model ComparisonUniversity {
  id              Int           @id @default(autoincrement())
  comparisonSetId Int
  universityId    Int
  createdAt       DateTime      @default(now())

  comparisonSet   ComparisonSet @relation(fields: [comparisonSetId], references: [id], onDelete: Cascade)
  university      University    @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([comparisonSetId, universityId])
  @@index([universityId])
}

model UserDeadline {
  id           Int         @id @default(autoincrement())
  userId       Int
  universityId Int
  deadlineType String
  important    Boolean     @default(false)
  note         String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  university   University  @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([userId, universityId, deadlineType])
  @@index([universityId])
}

model ChecklistItem {
  id        Int         @id @default(autoincrement())
  userId    Int
  title     String
  completed Boolean     @default(false)
  dueDate   DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents UserDocument[]
  calendarEvents CalendarEvent[]
}

model RecommendationPreference {
  id                     Int          @id @default(autoincrement())
  userId                 Int?
  preferredMajor         String?
  preferredCity          String?
  language               String?
  dormitoryRequired      Boolean?
  scholarshipPreferred   Boolean?
  level                  String?
  rankingMin             Int?
  rankingMax             Int?
  tuitionMin             Int?
  tuitionMax             Int?
  results                Json?
  createdAt              DateTime     @default(now())

  user                   StudentUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ContactMessage {
  id                   Int      @id @default(autoincrement())
  name                 String
  email                String
  universityOfInterest String?
  subject              String
  message              String   @db.Text
  status               String   @default("new")
  createdAt            DateTime @default(now())
}

model CommunityPost {
  id                Int                  @id @default(autoincrement())
  title             String
  content           String               @db.Text
  category          String
  universityId      Int?
  relatedProgram    String?
  tags              String[]             @default([])
  authorId          Int
  status            String               @default("published")
  pinned            Boolean              @default(false)
  officialAnswer    String?              @db.Text
  officialCommentId Int?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  author            StudentUser          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  university        University?          @relation(fields: [universityId], references: [id], onDelete: SetNull)
  comments          CommunityComment[]
  likes             CommunityLike[]
  savedBy           CommunitySavedPost[]
  reports           CommunityReport[]

  @@index([authorId])
  @@index([category])
  @@index([universityId])
  @@index([status])
  @@index([pinned])
  @@index([createdAt])
}

model CommunityComment {
  id              Int                @id @default(autoincrement())
  postId          Int
  authorId        Int
  content         String             @db.Text
  parentCommentId Int?
  status          String             @default("published")
  official        Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  post            CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          StudentUser        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment   CommunityComment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         CommunityComment[] @relation("CommentReplies")
  reports         CommunityReport[]

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([status])
}

model CommunityLike {
  userId    Int
  postId    Int
  createdAt DateTime      @default(now())

  user      StudentUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model CommunitySavedPost {
  userId    Int
  postId    Int
  createdAt DateTime      @default(now())

  user      StudentUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost  @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model CommunityReport {
  id              Int               @id @default(autoincrement())
  postId          Int?
  commentId       Int?
  reporterId      Int
  reason          String
  details         String?           @db.Text
  status          String            @default("pending")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  post            CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment         CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter        StudentUser       @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([commentId])
  @@index([reporterId])
  @@index([status])
}

model Notification {
  id                Int         @id @default(autoincrement())
  userId            Int
  type              String
  title             String
  message           String      @db.Text
  relatedEntityType String?
  relatedEntityId   Int?
  linkUrl           String?
  isRead            Boolean     @default(false)
  priority          String      @default("normal")
  createdAt         DateTime    @default(now())

  user              StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
}

model ModeratorActivityLog {
  id             Int        @id @default(autoincrement())
  adminUserId    Int?
  actionType     String
  targetEntity   String
  targetEntityId Int?
  previousStatus String?
  newStatus      String?
  metadata       Json?
  createdAt      DateTime   @default(now())

  adminUser      AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([targetEntity, targetEntityId])
  @@index([createdAt])
}

model ModeratorInternalNote {
  id             Int       @id @default(autoincrement())
  adminUserId    Int
  targetEntity   String
  targetEntityId Int?
  note           String    @db.Text
  createdAt      DateTime  @default(now())

  adminUser      AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([targetEntity, targetEntityId])
}

model AnalyticsEvent {
  id         Int          @id @default(autoincrement())
  userId     Int?
  sessionId  String?
  eventType  String
  entityType String?
  entityId   Int?
  metadata   Json?
  createdAt  DateTime     @default(now())

  user       StudentUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([eventType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model UserOnboardingPreference {
  id                    Int         @id @default(autoincrement())
  userId                Int         @unique
  desiredMajor          String?
  degreeLevel           String?
  preferredCity         String?
  languagePreference    String?
  budgetMin             Int?
  budgetMax             Int?
  qsRankMin             Int?
  qsRankMax             Int?
  dormitoryRequired     Boolean?
  scholarshipPreference String?
  targetIntake          String?
  educationLevel        String?
  preparationStage      String?
  nationality           String?
  testStatus            String?
  onboardingCompleted   Boolean     @default(false)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user                  StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserApplication {
  id                  Int             @id @default(autoincrement())
  userId              Int
  universityId        Int
  programId           String?
  status              String          @default("Interested")
  intake              String?
  applicationDeadline DateTime?
  submittedDate       DateTime?
  resultDate          DateTime?
  notes               String?         @db.Text
  priority            String          @default("normal")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                StudentUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  university          University      @relation(fields: [universityId], references: [id], onDelete: Cascade)
  documents           UserDocument[]
  calendarEvents      CalendarEvent[]

  @@index([userId, status])
  @@index([universityId])
  @@index([applicationDeadline])
}

model UserDocument {
  id              Int              @id @default(autoincrement())
  userId          Int
  applicationId   Int?
  checklistItemId Int?
  documentType    String
  title           String
  status          String           @default("missing")
  fileUrl         String?
  fileName        String?
  fileType        String?
  fileSize        Int?
  expirationDate  DateTime?
  notes           String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            StudentUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  application     UserApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  checklistItem   ChecklistItem?   @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([applicationId])
  @@index([checklistItemId])
  @@index([expirationDate])
}

model CalendarEvent {
  id              Int              @id @default(autoincrement())
  userId          Int
  title           String
  description     String?          @db.Text
  eventType       String
  startDate       DateTime
  endDate         DateTime?
  allDay          Boolean          @default(true)
  universityId    Int?
  programId       String?
  applicationId   Int?
  checklistItemId Int?
  roadmapStepId   String?
  status          String           @default("upcoming")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            StudentUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  university      University?      @relation(fields: [universityId], references: [id], onDelete: SetNull)
  application     UserApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  checklistItem   ChecklistItem?   @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)

  @@index([userId, startDate])
  @@index([eventType])
  @@index([status])
  @@index([applicationId])
}
