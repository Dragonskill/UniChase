generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id                       Int       @id @default(autoincrement())
  name                     String    @unique
  slug                     String?   @unique
  koreanName               String?
  city                     String
  country                  String    @default("South Korea")
  universityType           String    @default("private")
  qsRanking                Int?
  qsRankingYear            Int?
  rankingSourceNote        String?   @db.Text
  officialWebsite          String    @unique
  imageUrl                 String
  logoUrl                  String
  description              String    @db.Text
  programs                 String[]  @default([])
  tuitionMin               Int?
  tuitionMax               Int?
  tuitionCurrency          String    @default("KRW")
  admissionRequirements    String[]  @default([])
  languagesOfInstruction   String[]  @default([])
  scholarshipInfo          String?   @db.Text
  hasScholarships          Boolean   @default(false)
  hasDormitory             Boolean   @default(false)
  housingInfo              String?   @db.Text
  internationalStudentInfo String?   @db.Text
  studentLife              String?   @db.Text
  requiredDocuments        String[]  @default([])
  applicationSteps         String[]  @default([])
  studyLevels              String[]  @default([])
  applicationDeadlines     Json?
  applicationOpenDate      DateTime?
  applicationDeadline      DateTime?
  scholarshipDeadline      DateTime?
  documentDeadline         DateTime?
  tags                     String[]  @default([])
  contactEmail             String?
  contactPhone             String?
  contactAddress           String?
  mainColor                String    @default("#15397F")
  acceptanceRate           String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  savedBy             SavedUniversity[]
  comparisonItems     ComparisonUniversity[]
  deadlineReminders   UserDeadline[]
  degreePrograms      Program[]
  applicationRoadmaps ApplicationRoadmap[]
  documentChecklists  DocumentChecklist[]
  costEstimates       CostEstimate[]
  eligibilityResults  EligibilityResult[]
  reviews             UniversityReview[]

  @@index([city])
  @@index([country])
  @@index([universityType])
  @@index([qsRanking])
  @@index([applicationDeadline])
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StudentUser {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  passwordHash   String
  preferredMajor String?
  preferredCity  String?
  preferredLevel String?
  budgetMin      Int?
  budgetMax      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  savedUniversities         SavedUniversity[]
  comparisonSets            ComparisonSet[]
  deadlineReminders         UserDeadline[]
  checklistItems            ChecklistItem[]
  recommendationPreferences RecommendationPreference[]
  applicationRoadmaps       ApplicationRoadmap[]
  documentChecklists        DocumentChecklist[]
  essayDrafts               EssayDraft[]
  visaChecklistItems        VisaChecklistItem[]
  costEstimates             CostEstimate[]
  eligibilityResults        EligibilityResult[]
  universityReviews         UniversityReview[]
  reminderPreference        ReminderPreference?
  scheduledReminders        ScheduledReminder[]
}

model SavedUniversity {
  userId       Int
  universityId Int
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  user       StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University  @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@id([userId, universityId])
  @@index([universityId])
}

model ComparisonSet {
  id        Int      @id @default(autoincrement())
  userId    Int?
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  StudentUser?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ComparisonUniversity[]
}

model ComparisonUniversity {
  id              Int      @id @default(autoincrement())
  comparisonSetId Int
  universityId    Int
  createdAt       DateTime @default(now())

  comparisonSet ComparisonSet @relation(fields: [comparisonSetId], references: [id], onDelete: Cascade)
  university    University    @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([comparisonSetId, universityId])
  @@index([universityId])
}

model UserDeadline {
  id           Int      @id @default(autoincrement())
  userId       Int
  universityId Int
  deadlineType String
  important    Boolean  @default(false)
  note         String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University  @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([userId, universityId, deadlineType])
  @@index([universityId])
}

model ChecklistItem {
  id        Int       @id @default(autoincrement())
  userId    Int
  title     String
  completed Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecommendationPreference {
  id                   Int      @id @default(autoincrement())
  userId               Int?
  preferredMajor       String?
  preferredCity        String?
  language             String?
  dormitoryRequired    Boolean?
  scholarshipPreferred Boolean?
  level                String?
  rankingMin           Int?
  rankingMax           Int?
  tuitionMin           Int?
  tuitionMax           Int?
  results              Json?
  createdAt            DateTime @default(now())

  user StudentUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ContactMessage {
  id                   Int      @id @default(autoincrement())
  name                 String
  email                String
  universityOfInterest String?
  subject              String
  message              String   @db.Text
  status               String   @default("new")
  createdAt            DateTime @default(now())
}

model Program {
  id                    Int      @id @default(autoincrement())
  universityId          Int
  slug                  String   @unique
  name                  String
  degreeLevel           String
  languageOfInstruction String
  tuitionMin            Int?
  tuitionMax            Int?
  tuitionCurrency       String   @default("KRW")
  duration              String?
  requirements          String[] @default([])
  requiredDocuments     String[] @default([])
  applicationPeriod     String?
  careerOutcomes        String[] @default([])
  officialLink          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  university University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([universityId])
  @@index([degreeLevel])
  @@index([languageOfInstruction])
  @@index([name])
}

model ApplicationRoadmap {
  id                 Int      @id @default(autoincrement())
  userId             Int
  universityId       Int?
  targetMajor        String
  degreeLevel        String
  intake             String
  preparationStatus  String
  deadlinePreference String?
  progress           Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user       StudentUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University?   @relation(fields: [universityId], references: [id], onDelete: SetNull)
  steps      RoadmapStep[]

  @@index([userId])
  @@index([universityId])
}

model RoadmapStep {
  id          Int       @id @default(autoincrement())
  roadmapId   Int
  title       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  sortOrder   Int       @default(0)
  custom      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roadmap ApplicationRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
}

model DocumentChecklist {
  id            Int      @id @default(autoincrement())
  userId        Int
  universityId  Int?
  targetMajor   String?
  degreeLevel   String
  nationality   String?
  languageTrack String
  progress      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       StudentUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University?             @relation(fields: [universityId], references: [id], onDelete: SetNull)
  items      DocumentChecklistItem[]

  @@index([userId])
  @@index([universityId])
}

model DocumentChecklistItem {
  id          Int      @id @default(autoincrement())
  checklistId Int
  title       String
  description String?
  completed   Boolean  @default(false)
  optional    Boolean  @default(false)
  custom      Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checklist DocumentChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model EssayDraft {
  id               Int      @id @default(autoincrement())
  userId           Int
  title            String
  targetUniversity String?
  targetMajor      String?
  prompt           String?
  content          String   @db.Text
  feedback         Json?
  wordCount        Int      @default(0)
  characterCount   Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VisaChecklistItem {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CostEstimate {
  id            Int      @id @default(autoincrement())
  userId        Int
  universityId  Int?
  name          String
  inputs        Json
  breakdown     Json
  monthlyCost   Int      @default(0)
  semesterCost  Int      @default(0)
  yearlyCost    Int      @default(0)
  firstYearCost Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([universityId])
}

model EligibilityResult {
  id                  Int      @id @default(autoincrement())
  userId              Int
  universityId        Int?
  targetProgram       String
  degreeLevel         String
  educationLevel      String?
  gpa                 Float?
  englishScore        String?
  koreanScore         String?
  budget              Int?
  nationality         String?
  preferredLanguage   String?
  status              String
  score               Int      @default(0)
  missingRequirements String[] @default([])
  nextSteps           String[] @default([])
  rawInput            Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user       StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University? @relation(fields: [universityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([universityId])
  @@index([status])
}

model UniversityReview {
  id                   Int      @id @default(autoincrement())
  userId               Int
  universityId         Int
  academics            Int
  campusLife           Int
  dormitory            Int
  internationalSupport Int
  difficulty           Int
  costValue            Int
  location             Int
  overallRating        Int
  comment              String   @db.Text
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user       StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  university University  @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([universityId])
  @@index([status])
}

model ReminderPreference {
  id                      Int      @id @default(autoincrement())
  userId                  Int      @unique
  emailEnabled            Boolean  @default(false)
  applicationDeadline     Boolean  @default(true)
  documentChecklist       Boolean  @default(true)
  roadmapStep             Boolean  @default(true)
  visaChecklist           Boolean  @default(true)
  savedUniversityDeadline Boolean  @default(true)
  reminderDays            Int[]    @default([30, 14, 7, 1])
  customEmail             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduledReminder {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  title     String
  sendAt    DateTime
  status    String   @default("scheduled")
  metadata  Json?
  lastError String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user StudentUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([sendAt])
}
